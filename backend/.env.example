# Backend Environment Variables

# Database (optional - SQLite будет использоваться, если не указан)
# Для локальной разработки можно оставить пустым - будет использоваться SQLite
# Для production укажите DATABASE_URL от Neon.tech или другого PostgreSQL провайдера
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Render upload directory (optional)
# RENDER_UPLOAD_DIR=/opt/render/project/src/backend/uploads
